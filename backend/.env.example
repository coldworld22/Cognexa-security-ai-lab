ADMIN_PASSWORD=Javaheat@18880
ADMIN_DISPLAY_NAME=Administrator
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
AUTHZ_CACHE_TTL_SECONDS=300
DEFAULT_LLM_PROVIDER=qwen
DEFAULT_LLM_MODEL=qwen2.5-coder
