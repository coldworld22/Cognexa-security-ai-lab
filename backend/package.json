{
  "name": "@security-ai-lab/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for the self-hosted Security AI Lab assistant platform.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "ai",
    "assistant",
    "express",
    "postgres",
    "redis"
  ],
  "license": "MIT",
